# Server Configuration
PORT=4000

# Logging Configuration
LOG_LEVEL=INFO

# AI Model Configuration
# The provider is set in src/agent/config.ts — set the API key it expects:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
