{
  "name": "{{ cookiecutter.project_name }}",
  "version": "0.1.0",
  "description": "{{ cookiecutter.description }}",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node ./dist/index.js",
    "dev": "tsx watch ./src/index.ts",
    "lint": "npx @biomejs/biome check src",
    "lint:fix": "npx @biomejs/biome check --write src",
    "test": "npm run build && npm run lint && node --import tsx --test 'src/**/*.test.ts'"
  },
  "author": "",
  "license": "MIT",
  "keywords": [
    "a2a",
    "agent",
    "mcp",
    "typescript"
  ],
  "a2a": {
    "role": "{{ cookiecutter.agent_role }}",
    "constraints": [],
    "examples": [
      {
        "user": "Hello, how can you help me?",
        "agent": "I'm a general-purpose AI assistant. I can answer questions, help with tasks, and use available tools to find information for you. What would you like help with?"
      }
    ],
    "behavior": {
      "maxSteps": 5,
      "temperature": 0.5
    },
    "skills": [
      {
        "id": "{{ cookiecutter.project_name | skill_id_from_name }}",
        "name": "{{ cookiecutter.project_name | skill_id_from_name | skill_name_from_id }}",
        "description": "{{ cookiecutter.description }}",
        "tags": ["{{ cookiecutter.project_name | skill_id_from_name }}"],
        "examples": ["Hello, how can you help me?", "What can you do?"]
      }
    ]
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/mcp": "^1.0.21",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.103",
    "express": "^4.21.2",
    "uuid": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/express": "^5.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.3.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
